# AWS Bedrock Configuration
# Using the provided API key for Bedrock Claude
BEDROCK_API_KEY=api_key_here
AWS_REGION=us-west-2

# AWS Bedrock Claude Configuration
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.1

# GitHub Token (for MCP authentication)
GITHUB_TOKEN=your_github_token_here

# MCP Server Configuration
MCP_SERVER_URL=https://api.githubcopilot.com/mcp/x/git/readonly

# Input/Output Files
INPUT_FILE=input.txt
OUTPUT_FILE=result.md

